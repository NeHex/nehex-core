APP_NAME=NeHex Core API
APP_VERSION=v1.0.2
APP_ENV=dev
APP_PORT=7878
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
ADMIN_MANAGER_WEB=/nehex-admin
ADMIN_MANAGER_BUILD_ON_STARTUP=false
ADMIN_API_SECRET=please-change-me
ADMIN_API_CLIENT_ID=nehex-vuetify-admin
ADMIN_API_TOKEN_TTL_SECONDS=43200
ADMIN_COOKIE_DOMAIN=
ADMIN_PUBLIC_COOKIE_DOMAIN=
SIMPLE_CACHE_MAX_ENTRIES=1024
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_PREFIX=nehex:cache:
REDIS_CONNECT_RETRY_SECONDS=30
REDIS_SOCKET_CONNECT_TIMEOUT=1.0
REDIS_SOCKET_TIMEOUT=1.5

DB_HOST=127.0.0.1
DB_DRIVER=postgresql
DB_PORT=5432
DB_NAME=nehex_dtbs
DB_USER=nehex_dtbs
DB_PASSWORD=change-me
DB_URL=

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=5
DB_READ_TIMEOUT=15
DB_WRITE_TIMEOUT=15
DB_AUTO_CREATE_TABLES=false
DB_STARTUP_MAX_RETRIES=30
DB_STARTUP_RETRY_INTERVAL_SECONDS=2
TZ=Asia/Shanghai
